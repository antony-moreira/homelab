          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(cgroup_name) (netdata_cgroup_mem_usage_MiB_average) > 1",
          "legendFormat": "{{cgroup_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
